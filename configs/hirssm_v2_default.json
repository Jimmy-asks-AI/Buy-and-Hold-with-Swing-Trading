{
  "model_name": "HIRSSM_V2",
  "description": "Hierarchical Industry Rotation and Size-Style Switching Model V2",
  "rebalance": {
    "main_frequency": "monthly",
    "risk_check_frequency": "weekly",
    "signal_timing": "close_after_signal_date",
    "execution_timing": "next_trading_day_close",
    "min_weight_change_to_trade": 0.02
  },
  "data_contract": {
    "style_daily_path": "data_raw/index/akshare_csindex/daily_csindex",
    "style_pe_path": "data_raw/index/akshare_csindex/valuation_pe_lg",
    "style_pb_path": "data_raw/index/akshare_csindex/valuation_pb_lg",
    "industry_daily_path": "data_raw/index/akshare_sw_industry/daily_sw",
    "industry_classification_path": "data_raw/index/akshare_sw_industry/classification",
    "industry_snapshot_path": "data_raw/index/akshare_sw_industry/analysis_latest_sw",
    "industry_snapshot_backtest_allowed": false,
    "current_components_backtest_allowed": false,
    "macro_point_in_time_required": true,
    "macro_available_date_required": true,
    "macro_data_paths": {
      "china_10y_yield": "data_raw/macro/china_10y_yield.csv",
      "us_10y_yield": "data_raw/macro/us_10y_yield.csv",
      "cny_fx": "data_raw/macro/cny_fx.csv",
      "pmi": "data_raw/macro/pmi.csv",
      "m2_social_financing": "data_raw/macro/m2_social_financing.csv",
      "cpi_ppi": "data_raw/macro/cpi_ppi.csv",
      "commodity_index": "data_raw/macro/commodity_index.csv"
    },
    "macro_backtest_allowed_without_available_date": false,
    "historical_index_components_required_for_backtest": true
  },
  "asset_universe": {
    "style": {
      "large_cap": "000300",
      "mid_cap": "000905",
      "small_cap": "000852",
      "broad_market": "000985",
      "defensive_large": "000016",
      "dividend": "000922"
    },
    "industry": {
      "primary": "sw_level1",
      "enhanced_level2": [
        "801083",
        "801081",
        "801085",
        "801102",
        "801223",
        "801055",
        "801193",
        "801194",
        "801191"
      ],
      "avoid_parent_child_double_count": true
    }
  },
  "feature_pipeline": {
    "winsorize_quantile": 0.025,
    "standardization": "robust_zscore",
    "time_series_zscore_window": 756,
    "cross_sectional_zscore": true,
    "family_cluster_correlation_threshold": 0.75,
    "min_history_days": 504,
    "ohlc_features_require_full_bar": true
  },
  "factor_families": {
    "trend_momentum": {
      "features": ["ret_20", "ret_60", "ret_120", "ret_250", "ma_gap_60", "ma_gap_120", "ma_slope_60", "breakout_120"],
      "cluster_before_scoring": true
    },
    "relative_strength": {
      "features": ["excess_ret_20", "excess_ret_60", "excess_ret_120", "residual_momentum_60", "residual_momentum_120"],
      "require_absolute_trend_confirmation": true
    },
    "valuation": {
      "features": ["pe_percentile", "pb_percentile", "pe_spread", "pb_spread", "valuation_momentum"],
      "style_backtest_enabled": true,
      "industry_backtest_enabled": false,
      "require_trend_or_risk_compression": true
    },
    "risk_compression": {
      "features": ["vol_20", "vol_60", "downside_vol_60", "max_drawdown_120", "drawdown_recovery", "corr_to_market_120"],
      "high_risk_direction": -1
    },
    "reversal_overheat": {
      "features": ["ret_5", "ret_10", "ret_20", "rsi_14", "distance_to_ma20", "distance_to_ma60", "drawup_from_60d_low"],
      "state_dependent_direction": true
    },
    "liquidity_crowding": {
      "features": ["amount_zscore_60", "volume_zscore_60", "price_volume_confirmation", "crowding_score"],
      "extreme_crowding_discount": 0.7
    },
    "breadth_dispersion": {
      "features": ["industry_above_ma60_ratio", "industry_positive_ret20_ratio", "industry_return_dispersion", "industry_average_correlation"],
      "used_for_budget_not_ranking": true
    }
  },
  "regime_model": {
    "initial_method": "rule_based",
    "hmm_enabled": false,
    "hmm_trade_directly_allowed": false,
    "state_smoothing_days": 5,
    "states": ["risk_on_trend", "risk_on_overheat", "range_bound", "risk_off_decline", "crash_rebound"]
  },
  "experts": {
    "trend_continuation": {
      "enabled": true,
      "max_weight": 0.5
    },
    "style_trend_continuation": {
      "enabled": false,
      "scope": "style",
      "status": "observation",
      "parent_expert": "trend_continuation",
      "requires_walk_forward": true
    },
    "industry_trend_continuation": {
      "enabled": true,
      "scope": "industry",
      "status": "gated",
      "parent_expert": "trend_continuation",
      "requires_walk_forward": true
    },
    "valuation_repair": {
      "enabled": true,
      "max_weight": 0.25
    },
    "risk_compression": {
      "enabled": true,
      "max_weight": 0.35
    },
    "range_reversal": {
      "enabled": true,
      "max_weight": 0.3
    },
    "defensive": {
      "enabled": true,
      "max_weight": 0.7
    },
    "style_liquidity_overlay": {
      "enabled": false,
      "scope": "style",
      "status": "observation",
      "parent_expert": "liquidity_overlay",
      "requires_walk_forward": true
    },
    "industry_liquidity_overlay": {
      "enabled": true,
      "scope": "industry",
      "status": "gated",
      "parent_expert": "liquidity_overlay",
      "requires_walk_forward": true
    },
    "macro_liquidity_regime": {
      "enabled": false,
      "status": "observation",
      "requires_point_in_time_macro": true
    },
    "rate_sensitivity": {
      "enabled": false,
      "status": "observation",
      "requires_point_in_time_macro": true
    },
    "valuation_spread_repair": {
      "enabled": false,
      "status": "observation",
      "requires_historical_valuation": true
    },
    "industry_valuation_repair": {
      "enabled": false,
      "status": "observation",
      "requires_historical_industry_valuation": true
    },
    "defensive_cash_substitution": {
      "enabled": true,
      "status": "risk_control"
    },
    "ml_ranker": {
      "enabled": false,
      "max_weight": 0.15,
      "requires_walk_forward": true,
      "requires_pbo_check": true
    }
  },
  "disabled_experts_by_default": ["range_reversal", "style_trend_continuation"],
  "disabled_experts_reason": {
    "range_reversal": "Fails current full-sample RankIC and ablation gates; keep as observation expert until walk-forward IC gating is implemented.",
    "style_trend_continuation": "Style-level trend and relative-strength signals have negative 21-day RankIC and improve return/Sharpe/drawdown when disabled in pruning diagnostics."
  },
  "expert_gates": {
    "enabled": true,
    "train_years": 5,
    "test_years": 1,
    "horizon_days": 21,
    "min_observations": 24,
    "rank_ic_mean_min": 0.0,
    "positive_ic_rate_min": 0.52,
    "icir_min": 0.05,
    "baseline_10bps_sharpe": 0.455,
    "baseline_10bps_annual_return": 0.0867,
    "baseline_10bps_max_drawdown": -0.5455,
    "max_drawdown_allowed_slippage": 0.03,
    "candidate_experts": [
      "trend_continuation",
