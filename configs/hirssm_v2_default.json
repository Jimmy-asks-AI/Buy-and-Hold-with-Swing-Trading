      "industry_trend_continuation",
      "valuation_repair",
      "risk_compression",
      "range_reversal",
      "defensive",
      "liquidity_overlay",
      "style_liquidity_overlay",
      "industry_liquidity_overlay"
    ],
    "observation_experts": ["range_reversal", "style_trend_continuation", "style_liquidity_overlay"],
    "gated_experts": ["industry_liquidity_overlay", "industry_trend_continuation"],
    "always_observe_new_macro_experts": [
      "macro_liquidity_regime",
