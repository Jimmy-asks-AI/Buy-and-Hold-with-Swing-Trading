{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "long_hold_v4_formal_target_manifest_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target_manifest_id",
    "decision_date",
    "required_coverage_start",
    "required_coverage_end",
    "target_generation",
    "point_in_time_usage",
    "formal_inputs",
    "datasets"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "target_manifest_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "decision_date": {
      "type": "string",
      "format": "date"
    },
    "required_coverage_start": {
      "type": "string",
      "format": "date"
    },
    "required_coverage_end": {
      "type": "string",
      "format": "date"
    },
    "target_generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code_commit",
        "code_files",
        "config"
      ],
      "properties": {
        "code_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "code_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fileBinding"
          }
        },
        "config": {
          "$ref": "#/$defs/fileBinding"
        }
      }
    },
    "point_in_time_usage": {
      "$ref": "#/$defs/fileBinding"
    },
    "formal_inputs": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/roleBinding"
      },
      "allOf": [
        {
          "contains": {
            "properties": {
              "role": {
                "const": "validation_execution_states"
              }
            },
            "required": [
              "role"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "role": {
                "const": "validation_target_weights"
              }
            },
            "required": [
              "role"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "role": {
                "const": "validation_benchmark_returns"
              }
            },
            "required": [
              "role"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "role": {
                "const": "independent_execution_states"
              }
            },
            "required": [
              "role"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "role": {
                "const": "independent_target_weights"
              }
            },
            "required": [
              "role"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "role": {
                "const": "independent_benchmark_returns"
              }
            },
            "required": [
              "role"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "role": {
                "const": "trading_calendar"
              }
            },
            "required": [
              "role"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "role": {
                "const": "candidate_registry"
              }
            },
            "required": [
              "role"
            ]
          }
        }
      ]
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "dataset_id",
          "revision_id",
          "file_path",
          "file_sha256",
          "manifest_path",
          "manifest_sha256",
          "pit_status"
        ],
        "properties": {
          "dataset_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "revision_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "file_path": {
            "type": "string",
            "minLength": 1
          },
          "file_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "manifest_path": {
            "type": "string",
            "minLength": 1
          },
          "manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "pit_status": {
            "const": "QUALIFIED_PIT"
          }
        }
      }
    }
  },
  "$defs": {
    "fileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "roleBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "path",
        "sha256"
      ],
      "properties": {
        "role": {
          "enum": [
            "validation_execution_states",
            "validation_target_weights",
            "validation_benchmark_returns",
            "independent_execution_states",
            "independent_target_weights",
            "independent_benchmark_returns",
            "trading_calendar",
            "candidate_registry"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
